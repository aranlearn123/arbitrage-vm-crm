            "get": {
                "description": "List allocations with optional status, base, quote, and role filters",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Allocations"
                ],
                "summary": "List allocations",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Filter by status. Supports comma-separated values.",
                        "name": "status",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Filter by base asset. Supports comma-separated values.",
                        "name": "base",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Filter by quote asset. Supports comma-separated values.",
                        "name": "quote",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Filter by crowding role. Supports comma-separated values.",
                        "name": "role",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "default": 100,
                        "description": "Maximum rows to return",
                        "name": "limit",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/response.AllocationList"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/response.Error"
                        }
                    }
                }
            }
        },
